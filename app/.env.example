# Copy to .env and fill in. The CDK stack writes a populated .env onto the
# EC2 runner automatically; this file documents the variables.

# AWS region the table + DAX cluster live in.
AWS_REGION=us-east-1

# DynamoDB table name (CDK creates "ProductCatalog").
TABLE_NAME=ProductCatalog

# GSI used by the category Query (CDK creates "category-index").
CATEGORY_INDEX=category-index

# DAX cluster discovery endpoint. DAX has NO local emulator — this MUST point
# at a real cluster. Get it from the CDK output `DaxEndpoint` or the DAX
# console. Forms accepted by amazon-dax-client v1.2+:
#   dax://my-cluster.abc123.dax-clusters.us-east-1.amazonaws.com:8111   (unencrypted)
#   daxs://my-cluster.abc123.dax-clusters.us-east-1.amazonaws.com:9111  (TLS)
DAX_ENDPOINT=

# REST API port.
PORT=3000

# A DAX read served from cache is typically sub-millisecond; a miss (DAX ->
# DynamoDB) is several ms. The narrated log calls anything at/under this a HIT.
HIT_THRESHOLD_MS=2
